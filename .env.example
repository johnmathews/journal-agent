# Copy to .env and fill in values.
# Only API keys are needed for ingestion. Listing, editing, and stats
# work without any API keys. The seed command also needs no keys.

# Anthropic API (for OCR via Claude) — required for image ingestion
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (for Whisper transcription and embeddings) — required for
# voice ingestion and semantic search
OPENAI_API_KEY=sk-...

# Optional — for ingesting files shared via Slack URLs
# SLACK_BOT_TOKEN=xoxb-...

# Database path (default: journal.db in current directory)
# DB_PATH=/data/journal.db

# ChromaDB connection
# For local dev with docker-compose.dev.yml:
CHROMADB_HOST=localhost
CHROMADB_PORT=8401

# MCP server (endpoint will be at http://<host>:<port>/mcp)
MCP_HOST=0.0.0.0
MCP_PORT=8400

# CORS origins for REST API (comma-separated)
# For local dev with the journal-webapp on Vite:
API_CORS_ORIGINS=http://localhost:5173

# Timezone
# TZ=Europe/Amsterdam

# Log level (default: INFO)
# LOG_LEVEL=INFO
