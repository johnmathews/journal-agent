# Anthropic API (for OCR)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (for Whisper transcription and embeddings)
OPENAI_API_KEY=sk-...

# Database path (default: journal.db in current directory)
# DB_PATH=/data/journal.db

# ChromaDB connection
# CHROMADB_HOST=journal-chromadb
# CHROMADB_PORT=8000

# MCP server (endpoint will be at http://<host>:<port>/mcp)
# MCP_HOST=0.0.0.0
# MCP_PORT=8400

# Timezone
# TZ=Europe/Amsterdam

# Log level (default: INFO)
# LOG_LEVEL=INFO
